# DataForge — .dockerignore
# Keep the build context small and fast

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# Virtual environments (Docker creates its own)
.venv/
venv/
env/

# Development and IDE files
.git/
.gitignore
.github/
.vscode/
.idea/
*.swp
*.swo

# Documentation
README.md
*.md

# Test files
tests/
test_*
*_test.py

# Temporary files
tmp/
temp/
*.tmp
*.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# CI/CD
.github/
.circleci/

# Docker files themselves (not needed inside the image)
Dockerfile
docker-compose.yml
.dockerignore
